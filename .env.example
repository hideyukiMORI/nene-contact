APP_ENV=local
APP_DEBUG=false
APP_NAME=NeNe Contact
# Machine API key — gates the agent read surface /api/* (header X-NENE2-API-Key) that MCP
# tools map to (M6, charter §11). Unset → /api/* is closed (401). Keep out of version control.
# The local MCP server (tools/local-mcp-server.php, docs/integrations/mcp.md) reads the same
# key plus NENE_CONTACT_API_BASE_URL (default http://localhost:8900) from its own environment.
NENE2_MACHINE_API_KEY=
NENE2_LOCAL_JWT_SECRET=
PROBLEM_DETAILS_BASE_URL=https://nene-contact.dev/problems/

# --- Encryption (charter §6) ---
# At-rest key for notification channel secrets. Required when channels are used;
# generate with: php -r 'echo base64_encode(sodium_crypto_secretbox_keygen());'
NENE_CONTACT_ENCRYPTION_KEY=

# --- Multi-tenancy (ADR 0006 / ADR 0014) ---
TENANT_RESOLUTION=single
ORG_SLUG=default
BASE_DOMAIN=localhost

# --- Database (host / PHPUnit default: SQLite) ---
DATABASE_URL=
DB_ENV=local
DB_ADAPTER=sqlite
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=var/nene_contact.sqlite
DB_USER=nene_contact
DB_PASSWORD=
DB_CHARSET=utf8mb4

# --- Docker Compose overrides (copy to .env and uncomment for local stack) ---
# Local ports are fixed to the 89xx lane (CLAUDE.md): API 8900 / phpMyAdmin 8901 / MySQL 3391
# DB_ADAPTER=mysql
# DB_HOST=mysql
# DB_PORT=3306
# DB_NAME=nene_contact
# DB_USER=nene_contact
# DB_PASSWORD=nene_contact
# MYSQL_ROOT_PASSWORD=nene_contact_root
# NENE_CONTACT_PORT=8900
# NENE_CONTACT_PHPMYADMIN_PORT=8901
# NENE_CONTACT_MYSQL_PORT=3391

# --- Mail (Docker Mailpit; production uses your host SMTP relay) ---
# MAIL_DSN=smtp://mailpit:1025
# MAIL_FROM=noreply@nene-contact.local

# --- Sibling handoff (M5; HTTP only, never a shared DB — ADR 0002) ---
# Operator-triggered handoff of a submission to a sibling product. Tokens are bearer
# service credentials — keep them out of version control; they are never logged.
# Contact → Deal (create opportunity, DO D11):
# NENE_DEAL_API_BASE_URL=
# NENE_DEAL_SERVICE_TOKEN=
# Contact → Vault (archive a submission attachment as a received document, DO D12):
# NENE_VAULT_API_BASE_URL=
# NENE_VAULT_SERVICE_TOKEN=
