{
    "name": "hideyukimori/nene-contact",
    "description": "NeNe Contact — embeddable contact forms, submission inbox, and notifications on NENE2.",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.4.1 <9.0",
        "hideyukimori/nene2": "@dev",
        "psr/http-client": "^1.0",
        "symfony/http-client": "^8.1",
        "symfony/mailer": "^8.1"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../NENE2"
        }
    ],
    "autoload": {
        "psr-4": {
            "NeneContact\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "NeneContact\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --testsuite NeneContact",
        "analyse": "phpstan analyse --memory-limit 512M",
        "cs": "php-cs-fixer fix --dry-run --diff --config=.php-cs-fixer.php",
        "cs:fix": "php-cs-fixer fix --config=.php-cs-fixer.php",
        "openapi": "php tools/validate-openapi.php",
        "mcp": "php tools/validate-mcp-tools.php",
        "no-physical-delete": "php tools/check-no-physical-delete.php",
        "migrations:status": "phinx status -c phinx.php",
        "migrations:migrate": "phinx migrate -c phinx.php",
        "migrations:rollback": "phinx rollback -c phinx.php",
        "check": [
            "@test",
            "@analyse",
            "@cs",
            "@openapi",
            "@mcp",
            "@no-physical-delete"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.95",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^13.1",
        "robmorgan/phinx": "^0.16.11",
        "symfony/yaml": "^8.0"
    }
}
