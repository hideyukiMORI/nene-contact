<?xml version="1.0" encoding="UTF-8"?>
<phpunit
  bootstrap="vendor/autoload.php"
  colors="true"
  cacheDirectory=".phpunit.cache"
>
  <testsuites>
    <testsuite name="NeneContact">
      <directory>tests</directory>
    </testsuite>
  </testsuites>
  <php>
    <!-- HealthCheckTest boots the real DI container; GuardedJwtSecretResolver fails
         closed without this local-only opt-in when no real secret is configured. -->
    <env name="NENE2_ALLOW_DEV_SECRET" value="1" />
  </php>
  <source>
    <include>
      <directory>src</directory>
    </include>
  </source>
</phpunit>
