# Route all non-file/non-directory requests to the NENE2 front controller.
# Requires mod_rewrite + AllowOverride All (set in docker/php/Dockerfile).
RewriteEngine On

# Some CGI/FastCGI hosts drop the Authorization header before PHP sees it; re-deliver it as an
# env var so Bearer auth still works. Front proxies that strip it before Apache (HETEML) are
# covered by the console's X-Authorization mirror + NENE2's opt-in
# AuthorizationHeaderFallbackMiddleware (enableAuthorizationHeaderFallback, #375).
RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

# The operator console SPA lives under /console/ (built to public_html/console/). The admin
# **API** owns /admin/* — keeping the SPA on a separate prefix means API routes are never
# shadowed by the SPA fallback (#114). Old /admin bookmark → console for convenience.
RewriteRule ^admin/?$ /console/ [R=302,L]

# Console SPA client-side routing: serve the built SPA shell for non-file /console/* paths
# (deep links / reload). Real files (assets, index.html) are served directly.
RewriteCond %{REQUEST_URI} ^/console/
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ /console/index.html [L]

# Everything else (the /admin/* API, /public/*, /health, …) → NENE2 front controller.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.php [QSA,L]

# --- Cache-Control (#368) -------------------------------------------------------------------
# FilesMatch keys on the served filename, so these hold across /console/ and /embed/ regardless
# of the rewrites above.
<IfModule mod_headers.c>
    # HTML (the SPA shell + demo) must always revalidate, so a redeploy's new content-hashed
    # asset filenames are picked up immediately instead of a stale shell referencing old hashes.
    <FilesMatch "\.html$">
        Header set Cache-Control "no-cache"
    </FilesMatch>

    # Content-hashed build assets — the name changes whenever the bytes do, so cache forever.
    # Vite emits `name-<hash>.js|css|woff2`; the production embed is `embed.<hash>.js`.
    <FilesMatch "-[A-Za-z0-9_-]{8,}\.(js|css|woff2?)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    <FilesMatch "^embed\.[0-9a-f]{8,}\.js$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

    # The raw, unhashed embed source is a cache-busting-free install path — keep it short.
    <FilesMatch "^embed\.js$">
        Header set Cache-Control "public, max-age=300"
    </FilesMatch>
</IfModule>
